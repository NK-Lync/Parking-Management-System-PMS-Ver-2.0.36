@model IEnumerable<ParkingManagementSystem.Models.ParkingSession>

@{
    ViewData["Title"] = "Lịch Sử Ra Vào";
    var overlapMap = ViewBag.OverlapMap as Dictionary<string, int> ?? new Dictionary<string, int>();
    var zoneList = ViewBag.ZoneList as IEnumerable<string> ?? Enumerable.Empty<string>();
    var keyword = ViewBag.Keyword as string ?? string.Empty;
    var selectedStatus = ViewBag.SelectedStatus as string ?? string.Empty;
    var selectedZone = ViewBag.SelectedZone as string ?? string.Empty;
}

<div class="header-bar d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold" style="color: #2d3748;">
        <i class="fa fa-history me-2 text-primary"></i> NHẬT KÝ XE RA VÀO
    </h4>
    <div class="d-flex gap-2">
        <span class="badge bg-white text-dark border px-3 py-2 shadow-sm">
            <i class="fa fa-car me-1 text-success"></i> Tổng: @(Model?.Count() ?? 0) lượt
        </span>
        <form asp-action="DeleteAllHistory" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa TOÀN BỘ lịch sử ra vào?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">
                <i class="fa fa-trash me-1"></i> Xóa toàn bộ lịch sử
            </button>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card border-0 shadow-sm p-3 mb-3">
    <form asp-action="Index" method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label small text-muted fw-bold">Tìm kiếm (biển số / RFID / loại xe)</label>
            <input type="text" class="form-control" name="keyword" value="@keyword" placeholder="VD: 99E122268 hoặc RFID338050" />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted fw-bold">Trạng thái</label>
            <select class="form-select" name="status">
                @if (string.IsNullOrEmpty(selectedStatus))
                {
                    <option value="" selected>Tất cả</option>
                }
                else
                {
                    <option value="">Tất cả</option>
                }

                @if (selectedStatus == "active")
                {
                    <option value="active" selected>Đang ở trong bãi</option>
                }
                else
                {
                    <option value="active">Đang ở trong bãi</option>
                }

                @if (selectedStatus == "completed")
                {
                    <option value="completed" selected>Đã ra</option>
                }
                else
                {
                    <option value="completed">Đã ra</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted fw-bold">Zone</label>
            <select class="form-select" name="zone">
                @if (string.IsNullOrEmpty(selectedZone))
                {
                    <option value="" selected>Tất cả</option>
                }
                else
                {
                    <option value="">Tất cả</option>
                }
                @foreach (var z in zoneList)
                {
                    if (selectedZone == z)
                    {
                        <option value="@z" selected>@z</option>
                    }
                    else
                    {
                        <option value="@z">@z</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100 fw-bold">Lọc</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100 fw-bold">Reset</a>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr class="small text-uppercase fw-bold text-muted">
                    <th class="ps-4">Biển Số</th>
                    <th>Loại Xe</th>
                    <th>Vị Trí / Zone</th>
                    <th>Mã Thẻ (RFID)</th>
                    <th>Thời Gian Vào</th>
                    <th>Thời Gian Ra</th>
                    <th>Thời Lượng</th>
                    <th>Phí Gửi</th>
                    <th class="text-center">Trạng Thái</th>
                    <th class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        var start = item.CheckInTime;
                        var end = item.CheckOutTime ?? DateTime.Now;
                        var duration = start.HasValue ? (end - start.Value) : TimeSpan.Zero;
                        var plateKey = (item.LicensePlateIn ?? "").Replace(".", "").Replace("-", "").Replace(" ", "").ToUpperInvariant();
                        var overlapCount = overlapMap.TryGetValue(plateKey, out var count) ? count : 0;

                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-dark border px-3 py-2 fw-bold text-uppercase">
                                    @item.LicensePlateIn
                                </span>
                            </td>

                            <td>
                                <span class="text-muted small">
                                    <i class="fa fa-info-circle me-1 opacity-50"></i>
                                    @(item.Vehicle?.VehicleType?.TypeName ?? "Xe vãng lai")
                                </span>
                            </td>

                            <td>
                                @if (item.ParkingPosition != null)
                                {
                                    <span class="badge bg-info text-dark border-0">
                                        <i class="fa fa-map-marker-alt me-1 text-primary"></i>
                                        @item.ParkingPosition.Zone
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">---</span>
                                }
                            </td>

                            <td>
                                <code class="text-primary fw-bold">@(item.RFIDCard?.RfidCode ?? "N/A")</code>
                            </td>
                            <td class="small text-muted">
                                <i class="fa fa-clock me-1"></i> @(item.CheckInTime?.ToString("HH:mm dd/MM/yyyy") ?? "---")
                            </td>
                            <td class="small text-muted">
                                @if (item.CheckOutTime.HasValue)
                                {
                                    <i class="fa fa-clock me-1 text-danger"></i>
                                    @item.CheckOutTime.Value.ToString("HH:mm dd/MM/yyyy")
                                }
                                else
                                {
                                    <span class="text-italic opacity-50">---</span>
                                }
                            </td>
                            <td class="small">
                                <span class="text-dark">
                                    @($"{Math.Floor(duration.TotalHours)}h {duration.Minutes}m")
                                </span>
                            </td>
                            <td>
                                <span class="fw-bold text-primary">
                                    @(item.TotalFee.HasValue ? item.TotalFee.Value.ToString("N0") + " d" : "0 d")
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.CheckOutTime == null)
                                {
                                    <span class="badge rounded-pill bg-success px-3">
                                        <i class="fa fa-sign-in-alt me-1"></i> Đang ở trong bãi
                                    </span>
                                    @if (overlapCount > 1)
                                    {
                                        <div class="small text-danger fw-bold mt-1">Trùng @overlapCount phiên đang hoạt động</div>
                                    }
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-light text-muted border px-3">
                                        Đã thanh toán & Ra
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.CheckOutTime == null && overlapCount > 1)
                                {
                                    <form asp-action="ResolvePlateOverlap" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="licensePlate" value="@item.LicensePlateIn" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">Xử lý trùng</button>
                                    </form>
                                }
                                <form asp-action="DeleteSession" method="post" class="d-inline ms-1" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phiên này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="sessionId" value="@item.SessionId" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary fw-bold">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            <i class="fa fa-info-circle fa-2x mb-2"></i>
                            <p>Chưa có dữ liệu lượt gửi xe nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .table thead th {
        border-top: none;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .table tbody td {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .badge {
        font-weight: 600;
    }

    .bg-info {
        background-color: #e1f5fe !important;
        color: #0277bd !important;
    }
</style>
